# Anthropic API key (required unless using Vertex AI)
ANTHROPIC_API_KEY=

# Jira API token for Jira CLI
JIRA_API_TOKEN=
# Auth type for Jira (typically "bearer")
JIRA_AUTH_TYPE=bearer

# GitHub personal access token
GITHUB_TOKEN=

# GitLab personal access token (alternative to GitHub)
# GITLAB_TOKEN=

# Vertex AI configuration (uncomment to use Vertex AI instead of Anthropic API)
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=
